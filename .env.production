# ============================================================================
# ResumePilot AI — 生产环境变量 (仅供参考，不提交到 Git)
# ============================================================================
# 实际部署时通过环境变量注入 (Docker / K8s Secrets / Vercel Env)

# === 应用 ===
NODE_ENV=production
API_PORT=3001
WEB_PORT=3000
API_PREFIX=api/v1

# === 前端 (Next.js 构建时注入) ===
NEXT_PUBLIC_API_URL=https://api.resumepilot.ai

# === Cookie ===
# 生产环境必需！设置为你的域名，前面带点
COOKIE_DOMAIN=.resumepilot.ai

# === 数据库 (使用 PgBouncer 连接池) ===
# DATABASE_URL: 通过 PgBouncer (端口 6432)，用于 Prisma Client 查询
# DIRECT_URL: 直连 PostgreSQL (端口 5432)，用于 Prisma Migrate
DATABASE_URL=postgresql://user:password@pgbouncer:6432/resumepilot?schema=public&connection_limit=20&pool_timeout=10
DIRECT_URL=postgresql://user:password@postgres:5432/resumepilot?schema=public

# === Redis ===
REDIS_URL=redis://:password@redis:6379
REDIS_PASSWORD=your-redis-password

# === S3 (AWS S3 / Cloudflare R2) ===
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=resumepilot-prod-resumes
S3_USE_SSL=true

# === JWT (openssl rand -hex 64 生成) ===
JWT_ACCESS_SECRET=<64-char-random-hex-string>
JWT_REFRESH_SECRET=<64-char-random-hex-string>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=resumepilot-api

# === Bcrypt ===
BCRYPT_SALT_ROUNDS=12

# === OpenAI ===
OPENAI_API_KEY=sk-prod-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxx

# === 邮件 (Resend) ===
RESEND_API_KEY=re_xxxxxxxx

# === 速率限制 ===
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# === 日志 ===
LOG_LEVEL=info
LOG_PRETTY=false
