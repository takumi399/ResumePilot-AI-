# ============================================================================
# ResumePilot AI — 环境变量
# ============================================================================
# 复制此文件为 .env 并填入实际值
# ============================================================================

# === 应用 ===
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
APP_URL=http://localhost:3001

# === 前端地址 (CORS) ===
FRONTEND_URL=http://localhost:3000

# === 数据库 (PostgreSQL) ===
DATABASE_URL=postgresql://resumepilot:resumepilot@localhost:5432/resumepilot?schema=public

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# === JWT ===
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=resumepilot-api

# === Bcrypt ===
BCRYPT_SALT_ROUNDS=12

# === S3 兼容存储 ===
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=resumepilot-resumes
S3_USE_SSL=false

# === AI (支持 OpenAI / DeepSeek / 任何兼容 API) ===
# provider: openai | deepseek | custom
# DeepSeek: https://platform.deepseek.com/api_keys
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-your-deepseek-key-here
AI_MODEL=deepseek-chat
# Embedding (DeepSeek 暂不支持，用 OpenAI 兼容接口)
AI_EMBEDDING_BASE_URL=https://api.openai.com/v1
AI_EMBEDDING_API_KEY=sk-your-openai-key-here
AI_EMBEDDING_MODEL=text-embedding-3-small

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# === 邮件 (Resend) ===
RESEND_API_KEY=re_...

# === 日志 ===
LOG_LEVEL=debug
LOG_PRETTY=true

# === 速率限制 ===
THROTTLE_TTL=60
THROTTLE_LIMIT=100
